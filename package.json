{
  "name": "prestige-goal-motion-web",
  "version": "1.0.0",
  "description": "Web oficial de Dynasty Prestige - Alquiler de Coches de Lujo",
  "main": "server/backend-example.js",
  "scripts": {
    "start": "node server/backend-example.js",
    "dev": "node server/backend-example.js",
    "build:fleet": "node server/render-fleet-cards.js",
    "audit:inventory": "node scripts/audit-inventory.js",
    "audit:repo": "node server/audit-site.js",
    "audit:seo": "node server/audit-seo.js",
    "audit:final": "npm run test:core && npm run audit:seo && npm run test:e2e",
    "audit": "npm run audit:inventory && npm run audit:final",
    "verify": "node server/verificar-stripe.js",
    "test:smoke": "node server/test-server.js",
    "test:core": "npm run test:smoke && npm run audit:repo",
    "test:e2e": "playwright test",
    "test": "npm run audit:final",
    "http": "node server/server-http.js"
  },
  "keywords": [
    "stripe",
    "payment",
    "luxury-cars",
    "rental"
  ],
  "author": "Dynasty Prestige",
  "license": "ISC",
  "dependencies": {
    "@stripe/react-stripe-js": "^2.9.0",
    "@stripe/stripe-js": "^2.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "nodemailer": "^6.9.7",
    "stripe": "^14.25.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "axe-core": "^4.10.3"
  }
}
