{
  "name": "prestige-goal-motion-web",
  "version": "1.0.0",
  "description": "Web oficial de Dynasty Prestige - Alquiler de Coches de Lujo",
  "main": "server/apps/backend.js",
  "scripts": {
    "start": "node server/apps/backend.js",
    "dev": "node server/apps/backend.js",
    "qa:manual": "node scripts/qa/run-manual-rental-qa-env.js",
    "qa:manual:db": "node scripts/qa/run-manual-rental-qa-env.js --require-db",
    "qa:test:manual": "node scripts/qa/run-manual-rental-qa-test.js",
    "build:site": "npm run build:fleet && node scripts/build/write-runtime-config.js",
    "build:fleet": "node server/renderers/render-fleet-cards.js",
    "audit:quick": "npm run test:visual && npm run audit:navigation:quick && node scripts/audits/run-visual-smoke-audit.js --route / --route /fleet.html --route /contact.html --viewport mobile-modern --viewport laptop --output-dir artifacts/visual-audit-quick",
    "audit:strict": "npm run audit:navigation:strict && npm run audit:visual:robust && npm run audit:functional:master",
    "audit:ci": "npm run audit",
    "audit:inventory": "node scripts/audits/audit-inventory.js",
    "audit:structure": "node scripts/audits/run-structure-audit.js",
    "audit:connectivity:views": "node scripts/audits/run-view-connectivity-audit.js",
    "audit:connectivity:views:strict": "node scripts/audits/run-view-connectivity-audit.js --strict",
    "audit:repo": "node server/audits/audit-site.js",
    "audit:seo": "node scripts/audits/run-seo-agent.js --gate",
    "audit:seo:legacy": "node server/audits/audit-seo.js",
    "agent:seo": "node scripts/audits/run-seo-agent.js",
    "audit:copy": "node scripts/audits/run-copy-audit.js",
    "audit:cleanup": "node scripts/audits/run-project-cleanup-audit.js",
    "audit:mobile:pro": "node scripts/audits/run-mobile-pro-audit.js",
    "audit:mobile:full": "node scripts/audits/run-mobile-pro-audit.js --scope full",
    "audit:responsive": "playwright test tests/e2e/responsive-audit.spec.js --project=desktop-chromium",
    "audit:agentic": "node scripts/audits/run-agentic-audit.js",
    "audit:customer:journeys": "node scripts/audits/run-customer-journey-audit.js",
    "audit:navigation": "node scripts/audits/run-navigation-agent.js --deep --scope crawl --max-depth 10 --click-targets route-edges --viewport mobile-modern --viewport laptop --handoff-concurrency 12 --strict",
    "audit:navigation:quick": "node scripts/audits/run-navigation-agent.js --scope critical --max-clicks-per-page 2",
    "audit:navigation:critical": "node scripts/audits/run-navigation-agent.js --deep --scope critical --max-clicks-per-page 5 --click-targets route-edges",
    "audit:navigation:deep": "node scripts/audits/run-navigation-agent.js --deep --scope crawl --click-targets route-edges",
    "audit:navigation:matrix": "node scripts/audits/run-navigation-agent.js --full --click-targets route-edges --max-clicks-per-page 0",
    "audit:navigation:full": "node scripts/audits/run-navigation-agent.js --full --click-targets route-edges --handoff-concurrency 12",
    "audit:navigation:surfaces": "node scripts/audits/run-navigation-agent.js --full --click-targets route-surfaces --handoff-concurrency 12",
    "audit:navigation:exhaustive": "node scripts/audits/run-navigation-agent.js --full --click-targets all-actions --handoff-concurrency 12",
    "audit:navigation:strict": "node scripts/audits/run-navigation-agent.js --deep --scope crawl --max-depth 10 --click-targets route-edges --viewport mobile-modern --viewport laptop --handoff-concurrency 12 --strict",
    "audit:memory:check:navigation": "node scripts/audits/run-audit-memory.js --kind navigation --latest artifacts/navigation-agent",
    "audit:memory:approve:navigation": "node scripts/audits/run-audit-memory.js --approve --kind navigation --latest artifacts/navigation-agent",
    "audit:memory:check:functional": "node scripts/audits/run-audit-memory.js --kind functional --latest artifacts/functional-agent",
    "audit:memory:approve:functional": "node scripts/audits/run-audit-memory.js --approve --kind functional --latest artifacts/functional-agent",
    "audit:memory:check:visual": "node scripts/audits/run-audit-memory.js --kind visual --latest artifacts/visual-agent",
    "audit:memory:approve:visual": "node scripts/audits/run-audit-memory.js --approve --kind visual --latest artifacts/visual-agent",
    "agent:functional": "node scripts/audits/run-functional-agent.js",
    "agent:homogeneity": "node scripts/audits/run-homogeneity-agent.js",
    "agent:visual": "node scripts/audits/run-visual-agent.js",
    "audit:homogeneity": "node scripts/audits/run-homogeneity-agent.js --strict",
    "audit:homogeneity:components": "node scripts/design-system/run-component-contract-audit.js",
    "audit:homogeneity:layouts": "node scripts/design-system/run-layout-audit.js",
    "audit:homogeneity:headers": "node scripts/audits/run-header-homogeneity-guard.js",
    "agent:pricing": "node scripts/pricing/run-pricing-agent.js",
    "agent:pricing:apply": "node scripts/pricing/run-pricing-agent.js --apply",
    "audit:pricing": "node scripts/pricing/run-pricing-agent.js --strict",
    "admin:hash-password": "node scripts/admin/hash-admin-password.js",
    "admin:seed-demo": "node scripts/admin/seed-demo-reservation.js",
    "audit:visual": "npm run audit:visual:mobile && npm run audit:visual:tablet && npm run audit:visual:desktop",
    "audit:visual:mobile": "node scripts/audits/run-visual-smoke-audit.js --viewport-group mobile --output-dir artifacts/visual-audit-mobile",
    "audit:visual:tablet": "node scripts/audits/run-visual-smoke-audit.js --viewport-group tablet --output-dir artifacts/visual-audit-tablet",
    "audit:visual:desktop": "node scripts/audits/run-visual-smoke-audit.js --viewport-group desktop --output-dir artifacts/visual-audit-desktop",
    "audit:visual:responsive": "node scripts/audits/run-visual-smoke-audit.js --viewport-group responsive --output-dir artifacts/visual-audit-responsive",
    "audit:visual:smoke": "node scripts/audits/run-visual-smoke-audit.js",
    "audit:visual:robust": "node scripts/audits/run-visual-robust-audit.js",
    "audit:visual:robust:full": "node scripts/audits/run-visual-robust-audit.js --scope full",
    "audit:visual:memory": "node scripts/audits/run-change-guard-audit.js",
    "audit:visual:memory:responsive": "node scripts/audits/run-change-guard-audit.js --responsive",
    "audit:visual:memory:full": "node scripts/audits/run-change-guard-audit.js --full",
    "audit:visual:memory:approve": "node scripts/audits/run-change-guard-audit.js --approve-memory",
    "agent:visual:update-baselines": "node scripts/audits/run-visual-agent.js --update-baselines",
    "agent:visual:approve-latest": "node scripts/audits/run-visual-agent.js --approve-latest-clean",
    "audit:functional:missions": "playwright test tests/e2e/audit-customer-complete-flows.spec.js tests/e2e/services-to-reserve-funnels.spec.js tests/e2e/switch-car-mid-flow.spec.js --project=desktop-chromium --project=mobile-chromium",
    "audit:functional:contracts": "playwright test tests/e2e/audit-functional-surfaces.spec.js tests/e2e/reserve-negative.spec.js tests/e2e/services-deep-links.spec.js --project=desktop-chromium --project=mobile-chromium",
    "audit:functional:recovery": "playwright test tests/e2e/reserve-persistence.spec.js tests/e2e/functional-resilience.spec.js tests/e2e/api-failure-states.spec.js tests/e2e/complete-flow-error-recovery.spec.js tests/e2e/mobile-friction-points.spec.js --project=desktop-chromium --project=mobile-chromium",
    "audit:functional:adversarial": "playwright test tests/e2e/adversarial-functional-audit.spec.js --project=desktop-chromium --project=mobile-chromium",
    "audit:functional:production": "node scripts/qa/run-production-functional-gate.js",
    "audit:preprod:functional": "node scripts/qa/run-preprod-functional-gate.js",
    "audit:functional:deep": "node scripts/audits/run-functional-agent.js --deep",
    "audit:functional:master": "npm run audit:functional:missions && npm run audit:functional:contracts && npm run audit:functional:recovery && npm run audit:functional:adversarial",
    "test:admin:e2e": "playwright test tests/e2e/admin-content-editor.spec.js tests/e2e/admin-reservations-crm.spec.js --project=desktop-chromium",
    "audit:regression": "npm run test:visual && npm run audit:visual:memory:responsive",
    "audit:final": "npm run test:core && npm run audit:seo && npm run test:e2e",
    "audit": "npm run audit:inventory && npm run test:visual && npm run audit:connectivity:views:strict && npm run audit:visual && npm run audit:visual:memory:responsive && npm run audit:final",
    "verify": "node server/integrations/verify-stripe.js",
    "test:smoke": "node server/audits/test-server.js",
    "test:core": "npm run test:smoke && npm run audit:repo",
    "test:visual": "node --test tests/unit/audit-memory-core.test.js tests/unit/visual-audit-core.test.js tests/unit/visual-agent-runner.test.js tests/unit/view-connectivity-agent.test.js tests/unit/customer-journey-contract.test.js tests/unit/functional-audit-core.test.js tests/unit/navigation-audit-core.test.js tests/unit/seo-audit-core.test.js tests/unit/pricing-agent-core.test.js tests/unit/pricing-agent-runner.test.js tests/unit/homogeneity-audit-core.test.js tests/unit/layout-audit-core.test.js tests/unit/admin-auth.test.js tests/unit/admin-reservations.test.js tests/unit/availability-core.test.js tests/unit/render-global-header.test.js tests/unit/google-reviews.test.js tests/unit/reservation-lookup-security.test.js",
    "test:db": "node --test tests/integration/reservation-store-postgres.test.js",
    "test:e2e": "playwright test",
    "test:regression": "npm run audit:regression",
    "test:all": "npm run audit",
    "test": "npm run test:all",
    "http": "node server/apps/static-server.js"
  },
  "keywords": [
    "stripe",
    "payment",
    "luxury-cars",
    "rental"
  ],
  "author": "Dynasty Prestige",
  "license": "ISC",
  "dependencies": {
    "@stripe/react-stripe-js": "^2.9.0",
    "@stripe/stripe-js": "^2.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "nodemailer": "^6.9.7",
    "pg": "^8.13.1",
    "stripe": "^14.25.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "axe-core": "^4.10.3",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0"
  }
}
