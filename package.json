{
  "name": "prestige-goal-motion-web",
  "version": "1.0.0",
  "description": "Web oficial de Dynasty Prestige - Alquiler de Coches de Lujo",
  "main": "server/backend-example.js",
  "scripts": {
    "start": "node server/backend-example.js",
    "dev": "node server/backend-example.js",
    "build:fleet": "node server/render-fleet-cards.js",
    "audit:inventory": "node scripts/audit-inventory.js",
    "audit:connectivity:views": "node scripts/run-view-connectivity-audit.js",
    "audit:connectivity:views:strict": "node scripts/run-view-connectivity-audit.js --strict",
    "audit:repo": "node server/audit-site.js",
    "audit:seo": "node server/audit-seo.js",
    "audit:mobile:pro": "node scripts/run-mobile-pro-audit.js",
    "audit:mobile:full": "node scripts/run-mobile-pro-audit.js --scope full",
    "audit:responsive": "playwright test tests/e2e/responsive-audit.spec.js --project=desktop-chromium",
    "audit:agentic": "node scripts/run-agentic-audit.js",
    "audit:customer:journeys": "node scripts/run-customer-journey-audit.js",
    "audit:navigation": "node scripts/run-navigation-agent.js",
    "audit:navigation:critical": "node scripts/run-navigation-agent.js --scope critical",
    "audit:navigation:strict": "node scripts/run-navigation-agent.js --strict",
    "agent:functional": "node scripts/run-functional-agent.js",
    "agent:visual": "node scripts/run-visual-agent.js",
    "audit:visual:smoke": "node scripts/run-visual-smoke-audit.js",
    "audit:visual:robust": "node scripts/run-visual-robust-audit.js",
    "audit:visual:robust:full": "node scripts/run-visual-robust-audit.js --scope full",
    "agent:visual:update-baselines": "node scripts/run-visual-agent.js --update-baselines",
    "agent:visual:approve-latest": "node scripts/run-visual-agent.js --approve-latest-clean",
    "audit:functional:missions": "playwright test tests/e2e/audit-customer-complete-flows.spec.js tests/e2e/services-to-reserve-funnels.spec.js tests/e2e/switch-car-mid-flow.spec.js --project=desktop-chromium --project=mobile-chromium",
    "audit:functional:contracts": "playwright test tests/e2e/audit-functional-surfaces.spec.js tests/e2e/reserve-negative.spec.js tests/e2e/services-deep-links.spec.js --project=desktop-chromium --project=mobile-chromium",
    "audit:functional:recovery": "playwright test tests/e2e/reserve-persistence.spec.js tests/e2e/functional-resilience.spec.js tests/e2e/api-failure-states.spec.js tests/e2e/complete-flow-error-recovery.spec.js tests/e2e/mobile-friction-points.spec.js --project=desktop-chromium --project=mobile-chromium",
    "audit:functional:adversarial": "playwright test tests/e2e/adversarial-functional-audit.spec.js --project=desktop-chromium --project=mobile-chromium",
    "audit:functional:deep": "node scripts/run-functional-agent.js --deep",
    "audit:functional:master": "npm run audit:functional:missions && npm run audit:functional:contracts && npm run audit:functional:recovery",
    "audit:final": "npm run test:core && npm run audit:seo && npm run test:e2e",
    "audit": "npm run audit:inventory && npm run test:visual && npm run audit:connectivity:views:strict && npm run audit:visual:smoke && npm run audit:final",
    "verify": "node server/verificar-stripe.js",
    "test:smoke": "node server/test-server.js",
    "test:core": "npm run test:smoke && npm run audit:repo",
    "test:visual": "node --test tests/unit/visual-audit-core.test.js tests/unit/visual-agent-runner.test.js tests/unit/view-connectivity-agent.test.js tests/unit/customer-journey-contract.test.js tests/unit/functional-audit-core.test.js tests/unit/navigation-audit-core.test.js",
    "test:e2e": "playwright test",
    "test": "npm run audit:final",
    "http": "node server/server-http.js"
  },
  "keywords": [
    "stripe",
    "payment",
    "luxury-cars",
    "rental"
  ],
  "author": "Dynasty Prestige",
  "license": "ISC",
  "dependencies": {
    "@stripe/react-stripe-js": "^2.9.0",
    "@stripe/stripe-js": "^2.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "nodemailer": "^6.9.7",
    "stripe": "^14.25.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "axe-core": "^4.10.3",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0"
  }
}
