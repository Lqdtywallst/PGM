{
  "rewrites": [
    {
      "source": "/((?!app/).*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/reservas",
      "destination": "/#reserva",
      "permanent": true
    },
    {
      "source": "/reservas/",
      "destination": "/#reserva",
      "permanent": true
    },
    {
      "source": "/blog",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/blog/",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/stock-disponible-a-la-venta",
      "destination": "/#fleet",
      "permanent": true
    },
    {
      "source": "/nuestra-colección-exclusiva",
      "destination": "/#fleet",
      "permanent": true
    },
    {
      "source": "/nuestra-colección-exclusiva/",
      "destination": "/#fleet",
      "permanent": true
    }
  ]
}
