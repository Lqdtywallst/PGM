# Stripe configuration
# Copy this file to .env and fill in your real values

# Stripe secret key
# Get it at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here...

# Public Stripe publishable key for the static frontend.
# Browser-visible; use pk_test_ for QA/staging and pk_live_ only in production.
PGM_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here...

# Stripe webhook secret
# Get it at: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here...

# Server port
PORT=3000

# Environment
# Use NODE_ENV=production on Railway production and NODE_ENV=staging on Railway staging.
NODE_ENV=development
APP_ENV=development

# Reservation storage
# If DATABASE_URL is set, reservations are stored in PostgreSQL.
# Without it, local development stores ignored JSON files under output/runtime-reservations/.
# Set DATABASE_SSL=false for local Postgres; production defaults to SSL.
DATABASE_URL=
DATABASE_SSL=

# Optional frontend origins allowed to call the backend, comma-separated
# Local manual QA:
# ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
# Production backend:
# ALLOWED_ORIGINS=https://prestigegoalmotion.com,https://www.prestigegoalmotion.com
# Staging backend:
# ALLOWED_ORIGINS=https://staging.prestigegoalmotion.com,https://preprod.prestigegoalmotion.com,https://your-vercel-preview-url.vercel.app
ALLOWED_ORIGINS=https://prestigegoalmotion.com,https://www.prestigegoalmotion.com

# Public backend URL for static frontend builds/previews.
# Local manual QA uses http://localhost:3000.
PGM_PUBLIC_BACKEND_URL=http://localhost:3000

# Private admin reservations desk
# Generate the hash with: npm run admin:hash-password -- "your-strong-password"
ADMIN_USER=
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=
# Optional. In staging/production the admin cookie is Secure by default.
# Set explicitly to true in hosted environments if your provider uses APP_ENV differently.
ADMIN_COOKIE_SECURE=

# Mobile reservation alerts
# Option A: Telegram push notifications to the partner phone.
# Create a bot with BotFather, add it to a private chat/group, and set the chat id.
RESERVATION_TELEGRAM_BOT_TOKEN=
RESERVATION_TELEGRAM_CHAT_ID=
# Option B: generic webhook for Make/Zapier/Slack/Twilio/WhatsApp bridge.
RESERVATION_NOTIFICATION_WEBHOOK_URL=
RESERVATION_NOTIFICATION_WEBHOOK_SECRET=
# Optional explicit CRM link used in notification messages.
RESERVATION_CRM_URL=

# Optional local/integration PostgreSQL test target.
# Example: postgresql://pgm:pgm@localhost:55432/pgm_test
TEST_DATABASE_URL=
TEST_DATABASE_SSL=false

# Email transport
EMAIL_FROM=prestigegoalmotion@gmail.com
EMAIL_USER=prestigegoalmotion@gmail.com
EMAIL_PASSWORD=your_email_password_or_app_password

# Optional generic SMTP transport (preferred when not using Gmail)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Local-only helper: if SMTP is not configured, log contact messages instead of sending them
CONTACT_FORM_LOG_ONLY=false

# Optional SMTP escape hatch for self-signed certificates
SMTP_ALLOW_SELF_SIGNED=false

# Google Business reviews
# The website only displays review text returned by the official Google Places API.
# GOOGLE_PLACE_ID is required for both the API endpoint and the "Leave Google review" link.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
GOOGLE_REVIEWS_URL=https://www.google.com/maps/search/?api=1&query=Dynasty%20Prestige%20Luxury%20Car%20Rental%20Dubai
GOOGLE_WRITE_REVIEW_URL=
GOOGLE_REVIEWS_CACHE_TTL_MS=21600000


