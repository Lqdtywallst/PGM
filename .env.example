# Configuración de Stripe
# Copia este archivo a .env y completa con tus valores reales

# Clave secreta de Stripe (Secret Key)
# Obténla en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_TuClaveSecretaAqui...

# Secreto del Webhook de Stripe
# Obténlo en: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_TuWebhookSecretAqui...

# Puerto del servidor
PORT=3000

# Entorno
NODE_ENV=development

