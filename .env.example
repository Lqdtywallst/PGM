# Stripe configuration
# Copy this file to .env and fill in your real values

# Stripe secret key
# Get it at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here...

# Stripe webhook secret
# Get it at: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here...

# Server port
PORT=3000

# Environment
NODE_ENV=development

# Reservation storage
# If DATABASE_URL is set, reservations are stored in PostgreSQL.
# Without it, local development stores ignored JSON files under output/runtime-reservations/.
# Set DATABASE_SSL=false for local Postgres; production defaults to SSL.
DATABASE_URL=
DATABASE_SSL=

# Optional frontend origins allowed to call the backend, comma-separated
ALLOWED_ORIGINS=https://prestigegoalmotion.com,https://www.prestigegoalmotion.com

# Email transport
EMAIL_FROM=prestigegoalmotion@gmail.com
EMAIL_USER=prestigegoalmotion@gmail.com
EMAIL_PASSWORD=your_email_password_or_app_password

# Optional generic SMTP transport (preferred when not using Gmail)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Local-only helper: if SMTP is not configured, log contact messages instead of sending them
CONTACT_FORM_LOG_ONLY=false

# Optional SMTP escape hatch for self-signed certificates
SMTP_ALLOW_SELF_SIGNED=false



