# Dynasty Prestige - Apache Configuration for Production

# Enable compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Browser cache
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType application/json "access plus 0 seconds"
</IfModule>

# Headers de seguridad
<IfModule mod_headers.c>
    # Prevenir clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # XSS Protection
    Header always set X-XSS-Protection "1; mode=block"
    
    # Prevent MIME type sniffing
    Header always set X-Content-Type-Options "nosniff"
    
    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Permissions Policy
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    
    # Content Security Policy (adjust as needed)
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://js.stripe.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; img-src 'self' data: https:; font-src 'self' https://cdnjs.cloudflare.com; connect-src 'self' https://api.stripe.com; frame-src https://js.stripe.com;"
</IfModule>

# Custom redirects
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Redirect /reservations to reservations section
    RewriteRule ^reservations/?$ /#reserva [R=301,L]
    
    # Redirect /blog to home
    RewriteRule ^blog/?$ / [R=301,L]
    
    # Redirect /available-stock-for-sale to fleet
    RewriteRule ^available-stock-for-sale/?$ /#fleet [R=301,L]
    
    # Redirect /exclusive-collection to fleet
    RewriteRule ^exclusive-collection/?$ /#fleet [R=301,L]

    # Internal page organization rewrites
    RewriteRule ^luxury-car-rental-dubai\.html$ /pages/guides/luxury-car-rental-dubai.html [L]
    RewriteRule ^abu-dhabi-luxury-car-rental\.html$ /pages/guides/abu-dhabi-luxury-car-rental.html [L]
    RewriteRule ^dubai-airport-luxury-car-rental\.html$ /pages/guides/dubai-airport-luxury-car-rental.html [L]
    RewriteRule ^palm-jumeirah-luxury-car-rental\.html$ /pages/guides/palm-jumeirah-luxury-car-rental.html [L]
    RewriteRule ^dubai-marina-luxury-car-rental\.html$ /pages/guides/dubai-marina-luxury-car-rental.html [L]
    RewriteRule ^supercar-rental-dubai\.html$ /pages/guides/supercar-rental-dubai.html [L]
    RewriteRule ^airport-concierge-dubai\.html$ /pages/services/airport-concierge-dubai.html [L]
    RewriteRule ^chauffeur-service-dubai\.html$ /pages/services/chauffeur-service-dubai.html [L]
    RewriteRule ^hotel-villa-airport-delivery-dubai\.html$ /pages/services/hotel-villa-airport-delivery-dubai.html [L]
    RewriteRule ^wedding-event-car-rental-dubai\.html$ /pages/services/wedding-event-car-rental-dubai.html [L]
    RewriteRule ^business-car-rental-dubai\.html$ /pages/services/business-car-rental-dubai.html [L]
    RewriteRule ^monthly-luxury-car-rental-dubai\.html$ /pages/services/monthly-luxury-car-rental-dubai.html [L]
    RewriteRule ^lamborghini-rental-dubai\.html$ /pages/brands/lamborghini-rental-dubai.html [L]
    RewriteRule ^ferrari-rental-dubai\.html$ /pages/brands/ferrari-rental-dubai.html [L]
    RewriteRule ^mercedes-rental-dubai\.html$ /pages/brands/mercedes-rental-dubai.html [L]
    RewriteRule ^porsche-rental-dubai\.html$ /pages/brands/porsche-rental-dubai.html [L]
    RewriteRule ^rolls-royce-rental-dubai\.html$ /pages/brands/rolls-royce-rental-dubai.html [L]
    RewriteRule ^lamborghini-huracan-evo-spyder-rental-dubai\.html$ /pages/vehicles/lamborghini-huracan-evo-spyder-rental-dubai.html [L]
    RewriteRule ^lamborghini-urus-rental-dubai\.html$ /pages/vehicles/lamborghini-urus-rental-dubai.html [L]
    RewriteRule ^ferrari-296-gts-rental-dubai\.html$ /pages/vehicles/ferrari-296-gts-rental-dubai.html [L]
    RewriteRule ^mercedes-g63-amg-rental-dubai\.html$ /pages/vehicles/mercedes-g63-amg-rental-dubai.html [L]
    RewriteRule ^porsche-992-gt3-rental-dubai\.html$ /pages/vehicles/porsche-992-gt3-rental-dubai.html [L]
    RewriteRule ^rolls-royce-cullinan-black-badge-rental-dubai\.html$ /pages/vehicles/rolls-royce-cullinan-black-badge-rental-dubai.html [L]
    RewriteRule ^terms-and-conditions\.html$ /pages/legal/terms-and-conditions.html [L]
    RewriteRule ^terms-and-conditions-uae\.html$ /pages/legal/terms-and-conditions-uae.html [L]
    
    # HTTPS redirect (uncomment in production)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Prevent access to sensitive files
<FilesMatch "\.(env|log|md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Static file optimizations
<IfModule mod_mime.c>
    AddType image/webp .webp
    AddType image/avif .avif
    AddType application/manifest+json .webmanifest
</IfModule>

